#include <stdio.h>

int main() {
    int frames, pages, i, j, k, least, page_faults = 0;

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    int frame[frames], time[frames];
    for(i = 0; i < frames; i++) frame[i] = -1;

    printf("Enter number of pages: ");
    scanf("%d", &pages);

    int page[pages];
    printf("Enter pages: ");
    for(i = 0; i < pages; i++) scanf("%d", &page[i]);

    for(i = 0; i < pages; i++) {
        int found = 0;

        for(j = 0; j < frames; j++) {
            if(frame[j] == page[i]) {
                found = 1;
                time[j] = i;
                break;
            }
        }

        if(!found) {
            least = 0;
            for(j = 1; j < frames; j++) {
                if(time[j] < time[least])
                    least = j;
            }

            frame[least] = page[i];
            time[least] = i;
            page_faults++;
        }
    }

    printf("Page Faults = %d\n", page_faults);
    return 0;
}

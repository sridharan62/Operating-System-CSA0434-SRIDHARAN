#include <stdio.h>

int main() {
    int n, i, start, length;

    printf("Enter number of files: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("\nFile %d:\n", i+1);

        printf("Enter starting block: ");
        scanf("%d", &start);

        printf("Enter length: ");
        scanf("%d", &length);

        printf("Allocated blocks: ");
        for(int j = 0; j < length; j++) {
            printf("%d ", start + j);
        }
        printf("\n");
    }

    return 0;
}

#include <stdio.h>

int main() {
    int n, i, time = 0, completed = 0;
    int bt[20], rt[20], at[20], pr[20];
    int wt[20], tat[20], finish[20];
    int highest, min_pr;
    float avg_wt = 0, avg_tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        printf("\nProcess P%d\n", i+1);

        printf("Arrival Time: ");
        scanf("%d", &at[i]);

        printf("Burst Time: ");
        scanf("%d", &bt[i]);

        printf("Priority: ");
        scanf("%d", &pr[i]);

        rt[i] = bt[i];   // remaining time
    }

    while(completed < n) {
        highest = -1;
        min_pr = 999;

        for(i = 0; i < n; i++) {
            if(at[i] <= time && rt[i] > 0 && pr[i] < min_pr) {
                min_pr = pr[i];
                highest = i;
            }
        }

        if(highest == -1) {
            time++;
        } 
        else {
            rt[highest]--;
            time++;

            if(rt[highest] == 0) {
                completed++;
                finish[highest] = time;

                tat[highest] = finish[highest] - at[highest];
                wt[highest] = tat[highest] - bt[highest];

                avg_wt += wt[highest];
                avg_tat += tat[highest];
            }
        }
    }

    printf("\nProcess\tAT\tBT\tPriority\tWT\tTAT\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t\t%d\t%d\n",
               i+1, at[i], bt[i], pr[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt/n);
    printf("\nAverage Turnaround Time = %.2f\n", avg_tat/n);

    return 0;
}

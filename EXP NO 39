#include <stdio.h>
#include <stdlib.h>

void sort(int arr[], int n) {
    int i, j, temp;
    for(i = 0; i < n-1; i++)
        for(j = 0; j < n-i-1; j++)
            if(arr[j] > arr[j+1]) {
                temp = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = temp;
            }
}

int main() {
    int n, head, size, i, seek = 0;
    int req[50];

    printf("Enter number of requests: ");
    scanf("%d", &n);

    printf("Enter request sequence:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &req[i]);

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("Enter disk size: ");
    scanf("%d", &size);

    sort(req, n);

    // Move right
    for(i = 0; i < n; i++) {
        if(req[i] >= head) {
            seek += abs(req[i] - head);
            head = req[i];
        }
    }

    // Move to end
    seek += abs((size - 1) - head);

    // Jump to start
    seek += (size - 1);
    head = 0;

    // Continue servicing
    for(i = 0; i < n; i++) {
        if(req[i] < head) {
            seek += abs(req[i] - head);
            head = req[i];
        }
    }

    printf("Total Seek Time = %d\n", seek);
    return 0;
}

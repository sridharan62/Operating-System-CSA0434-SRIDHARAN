#include <stdio.h>

int main()
{
    FILE *fp;
    char data[100];
    int choice;

    while(1)
    {
        printf("\nFile Management Operations\n");
        printf("1. Create and Write File\n");
        printf("2. Read File\n");
        printf("3. Append File\n");
        printf("4. Delete File\n");
        printf("5. Exit\n");

        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
        case 1:
            fp = fopen("file.txt","w");
            printf("Enter text to write: ");
            scanf("%s", data);
            fprintf(fp,"%s",data);
            fclose(fp);
            printf("File created and data written successfully\n");
            break;

        case 2:
            fp = fopen("file.txt","r");
            if(fp == NULL)
            {
                printf("File does not exist\n");
                break;
            }
            fscanf(fp,"%s",data);
            printf("Data in file: %s\n",data);
            fclose(fp);
            break;

        case 3:
            fp = fopen("file.txt","a");
            printf("Enter text to append: ");
            scanf("%s",data);
            fprintf(fp,"%s",data);
            fclose(fp);
            printf("Data appended successfully\n");
            break;

        case 4:
            remove("file.txt");
            printf("File deleted successfully\n");
            break;

        case 5:
            return 0;

        default:
            printf("Invalid choice\n");
        }
    }

    return 0;
}

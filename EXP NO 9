#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>

int main()
{
    key_t key = 1234;
    int shmid;
    char *str;

    // Create shared memory
    shmid = shmget(key, 1024, 0666 | IPC_CREAT);

    // Attach shared memory
    str = (char*) shmat(shmid, NULL, 0);

    printf("Write Data: ");
    fgets(str, 100, stdin);

    printf("Data written in memory: %s\n", str);

    // Detach memory
    shmdt(str);

    return 0;
}
